---
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  { title: "Reformas de Cocina", desc: "Renovamos tu cocina con funcionalidad y diseño moderno adaptado a tus gustos.", image: "https://images.unsplash.com/photo-1556909114-44e3e70034e2?w=800&h=600&fit=crop", link: "/servicios/cocinas" },
  { title: "Reformas de Baño", desc: "Creamos baños cómodos y elegantes, cuidando cada detalle para tu bienestar.", image: "https://images.unsplash.com/photo-1552321554-5fefe8c9ef14?w=800&h=600&fit=crop", link: "/servicios/banos" },
  { title: "Reformas Integrales", desc: "Transformación completa de espacios con visión arquitectónica y ejecución impecable.", image: "https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=800&h=600&fit=crop", link: "/servicios/integrales" }
];

const stats = [
  { number: "20+", label: "Años de Experiencia" },
  { number: "2", label: "Años en Venezuela" },
  { number: "100%", label: "Compromiso y Calidad" },
  { number: "Rápida", label: "Ejecución Profesional" }
];
---

<BaseLayout 
  title="ReformaT Venezuela | Reformas de Calidad en Valencia y San Diego" 
  description="Más de 20 años transformando hogares y negocios en Valencia y San Diego, Carabobo. Reformas integrales, cocinas, baños, electricidad y fontanería con acabados impecables." 
  activePage="inicio"
>

  <!-- HERO -->
  <header class="hero">
    
    <!-- SCRIPT INLINE: Genera el video invisible que aparece suavemente al reproducirse -->
    <script is:inline>
      (function() {
        var isMobile = window.innerWidth < 1024;
        var videoSrc = isMobile ? '/videos/hero-mobile.mp4' : '/videos/hero-desktop.mp4';
        var posterSrc = isMobile ? 'https://images.unsplash.com/photo-1600607687920-4e2a09cf159d?q=80&w=1080&auto=format&fit=crop' : 'https://images.unsplash.com/photo-1600607687920-4e2a09cf159d?q=80&w=2070&auto=format&fit=crop';
        
        // opacity: 0 y transition para el fade-in suave
        var style = 'position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: 1; pointer-events: none; opacity: 0; transition: opacity 1s ease-in-out;';
        
        // onplaying="this.style.opacity=1" hace que aparezca suavemente apenas empieza
        document.write('<video id="hero-video" class="hero-video" autoplay muted loop playsinline preload="auto" poster="' + posterSrc + '" src="' + videoSrc + '" onplaying="this.style.opacity=1" style="' + style + '"></video>');
      })();
    </script>
    
    <noscript>
      <video id="hero-video" class="hero-video" autoplay muted loop playsinline preload="auto" poster="https://images.unsplash.com/photo-1600607687920-4e2a09cf159d?q=80&w=2070&auto=format&fit=crop" src="/videos/hero-desktop.mp4" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: 1;"></video>
    </noscript>

    <div class="hero-overlay"></div>

    <div class="hero-content">
      <span class="hero-tag">Calidad Excepcional en Valencia y San Diego</span>
      <h1 class="hero-title">
        <span class="line">Transformamos</span>
        <span class="line gold">Tu Hogar y Negocio</span>
        <span class="line">con Excelencia</span>
      </h1>
      <p class="hero-sub">Con más de 20 años de experiencia en reforma de viviendas y negocios, garantizamos acabados impecables y la mayor confianza.</p>
      <div class="hero-btns">
        <a href="/contacto" class="btn-premium btn-primary-premium">
          <span class="btn-content">Solicitar Presupuesto</span>
          <span class="btn-border"></span>
          <span class="btn-shine"></span>
          <span class="btn-arrow">→</span>
        </a>
        <a href="/servicios" class="btn-premium btn-outline-premium">
          <span class="btn-content">Explorar Servicios</span>
          <span class="btn-border"></span>
          <span class="btn-shine"></span>
          <span class="btn-arrow">→</span>
        </a>
      </div>
    </div>
  </header>

  <!-- STATS -->
  <section class="stats-section">
    <div class="container stats-grid">
      {stats.map((s) => (
        <div class="stat-item">
          <div class="stat-num">{s.number}</div>
          <div class="stat-label">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section bg-light">
    <div class="container">
      <div class="section-header">
        <span class="tag">Nuestros Servicios</span>
        <h2 class="section-title">Damos Vida a Tus Espacios</h2>
        <p class="section-desc">Reformas integrales, cocinas, baños, electricidad y fontanería. Ejecución rápida, técnicas avanzadas y acabados impecables.</p>
      </div>
      <div class="services-vertical-grid">
        {services.map((svc) => (
          <a href={svc.link} class="service-vertical-card">
            <div class="card-img-wrap">
              <img src={svc.image} alt={svc.title} loading="lazy" />
              <div class="card-overlay"></div>
              <span class="card-icon">✦</span>
            </div>
            <div class="card-body">
              <h3>{svc.title}</h3>
              <p>{svc.desc}</p>
              <span class="card-link">Descubrir más <span class="arrow">→</span></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="section">
    <div class="container about-grid">
      <div class="about-imgs">
        <div class="img-box tall">
          <img src="https://images.unsplash.com/photo-1503387762-592deb58ef4e?w=600" alt="Arquitectura" />
        </div>
        <div class="img-box small">
          <img src="https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=600" alt="Equipo" />
        </div>
      </div>
      <div class="about-text">
        <span class="tag">Sobre Nosotros</span>
        <h2 class="section-title">Experiencia Europea,<br/>Ejecución Local</h2>
        <p>ReformaT nace en España con más de 20 años de trayectoria en el sector de las reformas. Desde hace casi 2 años trabajamos en Venezuela, trayendo innovación, técnicas avanzadas y estándares europeos adaptados al mercado local de Valencia y San Diego, Carabobo.</p>
        <ul class="check-list">
          <li>Reformas integrales que transforman cada rincón con excelencia</li>
          <li>Servicios eléctricos y de fontanería con máxima seguridad</li>
          <li>Diseños personalizados que unen funcionalidad y estilo</li>
          <li>Asesoramiento experto y ejecución eficiente sin sorpresas</li>
        </ul>
        <a href="/contacto" class="btn-premium btn-primary-premium">
          <span class="btn-content">Comenzar Conversación</span>
          <span class="btn-border"></span>
          <span class="btn-shine"></span>
          <span class="btn-arrow">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-wrapper">
      <h2 class="cta-title">Tu Espacio, Nuestra Pasión</h2>
      <p class="cta-text">Cada proyecto comienza con una conversación. Cuéntanos tu visión y hagamos realidad el espacio de tus sueños.</p>
      <a href="/contacto" class="btn-premium btn-white-premium">
        <span class="btn-content">Agendar Consulta Gratuita</span>
        <span class="btn-border"></span>
        <span class="btn-shine"></span>
        <span class="btn-arrow">→</span>
      </a>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="section bg-light">
    <div class="container contact-grid">
      <div class="contact-info">
        <h2 class="section-title">Hablemos de Tu Proyecto</h2>
        <p>Estamos aquí para escuchar, asesorar y crear junto a ti. Trabajamos en toda el área de Valencia y San Diego, Carabobo.</p>
        <div class="info-item">
          <h4>Ubicación</h4>
          <p>Valencia y San Diego, Carabobo</p>
        </div>
        <div class="info-item">
          <h4>Teléfono</h4>
          <p>0422 799 7043</p>
        </div>
      </div>
      <form class="contact-form">
        <div class="form-row">
          <input type="text" placeholder="Nombre" required />
          <input type="tel" placeholder="Teléfono" required />
        </div>
        <input type="email" placeholder="Email" required />
        <select required>
          <option value="" disabled selected>Tipo de Proyecto</option>
          <option value="cocina">Reforma de Cocina</option>
          <option value="bano">Reforma de Baño</option>
          <option value="integral">Reforma Integral</option>
          <option value="electricidad">Servicios Eléctricos</option>
          <option value="fontaneria">Fontanería</option>
        </select>
        <textarea placeholder="Tu Mensaje" rows="4"></textarea>
        <button type="submit" class="btn-premium btn-primary-premium full-width">
          <span class="btn-content">Enviar Mensaje</span>
          <span class="btn-border"></span>
          <span class="btn-shine"></span>
          <span class="btn-arrow">→</span>
        </button>
      </form>
    </div>
  </section>

</BaseLayout>

<style>
  .hero { 
    position: relative; 
    width: 100%; 
    min-height: 100vh; 
    min-height: 100svh; 
    overflow: hidden; 
    background: #111 url('https://images.unsplash.com/photo-1600607687920-4e2a09cf159d?q=80&w=2070&auto=format&fit=crop') center/cover no-repeat;
    display: flex; 
    align-items: center; 
    justify-content: center; 
    text-align: center; 
    color: var(--white); 
  }
  
  .hero-video { z-index: 1; } 
  
  .hero-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(0,0,0,0.45), rgba(0,0,0,0.55) 50%, rgba(0,0,0,0.85)); z-index: 2; }
  .hero-content { position: relative; z-index: 3; max-width: 900px; padding: 0 20px; }
  .hero-tag { display: block; font-size: 0.9rem; letter-spacing: 3px; text-transform: uppercase; color: var(--gold); margin-bottom: 20px; }
  .hero-title { font-family: var(--font-serif); font-size: clamp(3rem, 8vw, 7rem); font-weight: 400; margin-bottom: 30px; line-height: 1.1; }
  .hero-title .line { display: block; }
  .hero-title .gold { color: var(--gold); }
  .hero-sub { font-size: 1.2rem; color: rgba(255, 255, 255, 0.95); margin: 0 auto 40px; max-width: 600px; line-height: 1.6; }
  .hero-btns { display: flex; gap: 25px; justify-content: center; flex-wrap: wrap; }
  
  .btn-outline-premium { background: transparent; color: var(--white); border: 1px solid rgba(255,255,255,0.4); backdrop-filter: blur(5px); }
  .btn-outline-premium:hover { transform: translateY(-3px); border-color: var(--gold); color: var(--gold); }
  .btn-white-premium { background: var(--white); color: var(--bg); box-shadow: 0 4px 15px rgba(0,0,0,0.2); }
  .btn-white-premium .btn-border { border: 2px solid var(--white); }
  .btn-white-premium:hover { transform: translateY(-3px); background: var(--gold); box-shadow: 0 8px 30px rgba(201, 169, 97, 0.5); }
  .btn-white-premium:hover .btn-arrow { transform: translateX(8px); }
  .btn-white-premium:hover .btn-shine { left: 150%; }

  .section { padding: 100px 0; }
  .bg-light { background: var(--gray); }
  .section-header { text-align: center; max-width: 700px; margin: 0 auto 60px; }
  .section-title { font-family: var(--font-serif); font-size: clamp(2rem, 5vw, 3.5rem); margin-bottom: 20px; font-weight: 400; }
  .tag { display: inline-block; color: var(--gold); font-size: 0.85rem; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 15px; font-weight: 600; }
  .section-desc { color: var(--gray-text); font-size: 1.1rem; line-height: 1.8; font-weight: 400; }
  .stats-section { padding: 60px 0; background: var(--bg); color: var(--white); }
  .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 30px; text-align: center; }
  .stat-num { font-family: var(--font-serif); font-size: 3.5rem; color: var(--gold); line-height: 1; margin-bottom: 10px; font-weight: 400; }
  .stat-label { font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px; opacity: 0.8; }
  .services-vertical-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; }
  .service-vertical-card { display: block; background: var(--white); border-radius: 8px; overflow: hidden; box-shadow: 0 5px 20px rgba(0,0,0,0.05); transition: 0.4s; text-decoration: none; color: inherit; }
  .service-vertical-card:hover { transform: translateY(-10px); box-shadow: 0 20px 50px rgba(0,0,0,0.12); }
  .card-img-wrap { position: relative; height: 280px; overflow: hidden; }
  .card-img-wrap img { width: 100%; height: 100%; object-fit: cover; transition: 0.6s; }
  .service-vertical-card:hover .card-img-wrap img { transform: scale(1.08); }
  .card-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.4) 0%, transparent 50%); }
  .card-icon { position: absolute; bottom: 15px; right: 15px; width: 45px; height: 45px; background: var(--gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; color: var(--bg); transition: 0.4s; }
  .service-vertical-card:hover .card-icon { transform: scale(1.15) rotate(15deg); }
  .card-body { padding: 30px 25px; }
  .card-body h3 { font-family: var(--font-serif); font-size: 1.5rem; margin-bottom: 12px; font-weight: 500; }
  .card-body p { color: var(--gray-text); font-size: 0.95rem; line-height: 1.7; margin-bottom: 20px; font-weight: 400; }
  .card-link { color: var(--gold); font-weight: 600; font-size: 0.85rem; display: inline-flex; align-items: center; gap: 8px; }
  .arrow { transition: transform 0.3s; }
  .service-vertical-card:hover .card-link { gap: 14px; }
  .service-vertical-card:hover .card-link .arrow { transform: translateX(5px); }
  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
  .about-imgs { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .img-box { border-radius: 4px; overflow: hidden; }
  .img-box.tall { grid-row: span 2; }
  .img-box img { width: 100%; height: 100%; object-fit: cover; }
  .check-list { margin: 30px 0; list-style: none; }
  .check-list li { margin-bottom: 15px; padding-left: 25px; position: relative; color: var(--gray-text); line-height: 1.6; font-weight: 400; }
  .check-list li::before { content: "✓"; position: absolute; left: 0; color: var(--gold); font-weight: bold; }
  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; }
  .info-item { margin-bottom: 25px; }
  .info-item h4 { font-size: 1rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 5px; font-weight: 600; }
  .info-item p { color: var(--gray-text); }
  .contact-form { background: var(--white); padding: 40px; border-radius: 8px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
  .contact-form input, .contact-form select, .contact-form textarea { width: 100%; padding: 15px; margin-bottom: 20px; border: 1px solid #ddd; background: #f9f9f9; border-radius: 4px; font-family: inherit; font-size: 1rem; }
  .contact-form input:focus, .contact-form textarea:focus { outline: none; border-color: var(--gold); }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .full-width { width: 100%; justify-content: center; }
  @media (max-width: 1023px) { .hero-tag{font-size:0.75rem;letter-spacing:2px;margin-bottom:15px;} .hero-title{font-size:clamp(2.2rem,10vw,3.5rem);margin-bottom:20px;} .hero-sub{font-size:1rem;margin-bottom:30px;padding:0 10px;} .hero-btns{flex-direction:column;align-items:center;gap:15px;width:100%;padding:0 20px;} .hero-btns .btn-premium{width:100%;max-width:280px;justify-content:center;} }
  @media (max-width: 900px) { .stats-grid{grid-template-columns:repeat(2,1fr);} .services-vertical-grid{grid-template-columns:1fr;max-width:500px;margin:0 auto;} .about-grid,.contact-grid{grid-template-columns:1fr;} }
  @media (prefers-reduced-motion: reduce) { .hero-video{display:none!important;} .hero{background:url('https://images.unsplash.com/photo-1600607687920-4e2a09cf159d?q=80&w=2070&auto=format&fit=crop') center/cover no-repeat;} }
</style>

<script>
  if(typeof gsap!=='undefined'){gsap.registerPlugin(ScrollTrigger);gsap.from('.hero-tag',{opacity:0,y:20,duration:1});gsap.from('.hero-title .line',{y:50,opacity:0,duration:1,stagger:0.15,delay:0.3});gsap.utils.toArray('.stat-num').forEach(el=>{const t=el.textContent;gsap.from(el,{innerText:0,duration:2,snap:{innerText:1},ease:'power2.out',scrollTrigger:{trigger:el,start:'top 85%'}});});}
</script>