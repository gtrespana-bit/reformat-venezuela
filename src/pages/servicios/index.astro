---
import BaseLayout from '../../layouts/BaseLayout.astro';
const services = [
  { slug: "cocinas", title: "Reformas de Cocina", desc: "Diseñamos cocinas funcionales y elegantes.", image: "/images/cocina.jpg", features: ["Diseño personalizado", "Materiales premium", "Optimización del espacio"] },
  { slug: "banos", title: "Reformas de Baño", desc: "Espacios de bienestar con acabados premium.", image: "https://images.unsplash.com/photo-1552321554-5fefe8c9ef14?w=800&h=600&fit=crop", features: ["Impermeabilización garantizada", "Diseño spa moderno", "Grifería de alta gama"] },
  { slug: "integrales", title: "Reformas Integrales", desc: "Transformación completa de viviendas y locales.", image: "https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=800&h=600&fit=crop", features: ["Proyecto completo", "Gestión de permisos", "Entrega garantizada"] },
  { slug: "electricidad", title: "Servicios Eléctricos", desc: "Instalaciones eléctricas seguras y eficientes.", image: "https://images.unsplash.com/photo-1621905224614-8e2b5f562c5f?w=800&h=600&fit=crop", features: ["Instalación certificada", "Domótica básica", "Revisión de seguridad"] },
  { slug: "fontaneria", title: "Fontanería", desc: "Soluciones profesionales en fontanería.", image: "https://images.unsplash.com/photo-1585704032915-c3400ca199e7?w=800&h=600&fit=crop", features: ["Detección de fugas", "Cambio de grifería", "Calefacción"] },
  { slug: "pintura", title: "Pintura y Acabados", desc: "Acabados perfectos con técnicas decorativas.", image: "https://images.unsplash.com/photo-1562259949-e8e7689d7828?w=800&h=600&fit=crop", features: ["Pintura decorativa", "Microcemento", "Efectos especiales"] }
];
---
<BaseLayout title="Servicios | ReformaT Venezuela" description="Soluciones completas en reformas." activePage="servicios">
  <header class="page-hero"><div class="hero-bg" style="background-image: url('https://images.unsplash.com/photo-1600585154526-990dced4db0d?q=80&w=2070&auto=format&fit=crop')"></div><div class="hero-overlay"></div><div class="hero-content"><span class="hero-tag">Lo Que Hacemos</span><h1 class="page-title">Soluciones de <span class="gold">Reforma Integral</span></h1><p class="page-subtitle">Más de 20 años transformando espacios en Valencia y San Diego.</p></div></header>
  <section class="services-page"><div class="container"><div class="section-header"><span class="tag">Nuestros Servicios</span><h2 class="section-title">Transformamos Cada Rincón de Tu Hogar</h2><p class="section-desc">Soluciones completas desde reformas parciales hasta proyectos integrales.</p></div><div class="services-vertical-grid">{services.map((svc) => (<a href={`/servicios/${svc.slug}`} class="service-vertical-card"><div class="card-img-wrap"><img src={svc.image} alt={svc.title} loading="lazy" /><div class="card-overlay"></div><span class="card-icon">✦</span></div><div class="card-body"><h3>{svc.title}</h3><p>{svc.desc}</p><ul class="card-features">{svc.features.map(f => <li>{f}</li>)}</ul><span class="card-link">Ver más detalles <span class="arrow">→</span></span></div></a>))}</div></div></section>
  
  <section class="cta-section">
    <div class="cta-wrapper">
      <h2 class="cta-title">¿Listo Para Transformar Tu Espacio?</h2>
      <p class="cta-text">Solicita una consulta gratuita y recibe un presupuesto detallado.</p>
      <a href="/contacto" class="btn-premium btn-primary-premium"><span class="btn-content">Agendar Consulta Gratuita</span><span class="btn-border"></span><span class="btn-shine"></span><span class="btn-arrow">→</span></a>
    </div>
  </section>
</BaseLayout>