---
// src/pages/servicios/index.astro
const services = [
  { slug: "cocinas", title: "Reformas de Cocina", desc: "Diseñamos cocinas funcionales y elegantes que se convierten en el corazón de tu hogar.", image: "https://images.unsplash.com/photo-1556909114-44e3e70034e2?w=800&h=600&fit=crop", features: ["Diseño personalizado", "Materiales premium", "Optimización del espacio"] },
  { slug: "banos", title: "Reformas de Baño", desc: "Espacios de bienestar con acabados premium y diseños modernos.", image: "https://images.unsplash.com/photo-1552321554-5fefe8c9ef14?w=800&h=600&fit=crop", features: ["Impermeabilización garantizada", "Diseño spa moderno", "Grifería de alta gama"] },
  { slug: "integrales", title: "Reformas Integrales", desc: "Transformación completa de viviendas y locales comerciales.", image: "https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=800&h=600&fit=crop", features: ["Proyecto completo", "Gestión de permisos", "Entrega garantizada"] },
  { slug: "electricidad", title: "Servicios Eléctricos", desc: "Instalaciones eléctricas seguras y eficientes.", image: "https://images.unsplash.com/photo-1621905224614-8e2b5f562c5f?w=800&h=600&fit=crop", features: ["Instalación certificada", "Domótica básica", "Revisión de seguridad"] },
  { slug: "fontaneria", title: "Fontanería", desc: "Soluciones profesionales en fontanería.", image: "https://images.unsplash.com/photo-1585704032915-c3400ca199e7?w=800&h=600&fit=crop", features: ["Detección de fugas", "Cambio de grifería", "Calefacción"] },
  { slug: "pintura", title: "Pintura y Acabados", desc: "Acabados perfectos con técnicas decorativas modernas.", image: "https://images.unsplash.com/photo-1562259949-e8e7689d7828?w=800&h=600&fit=crop", features: ["Pintura decorativa", "Microcemento", "Efectos especiales"] }
];
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Servicios | ReformaT Venezuela</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600;700&family=Manrope:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" defer></script>
</head>
<body>
  <nav id="navbar" class="nav">
    <div class="nav-container">
      <a href="/" class="logo">ReformaT<span class="dot">.</span></a>
      <ul class="nav-links">
        <li><a href="/">Inicio</a></li>
        <li><a href="/servicios" class="active">Servicios</a></li>
        <li><a href="/proyectos">Proyectos</a></li>
        <li><a href="/contacto" class="btn-nav-premium">Contacto</a></li>
      </ul>
      <button id="menu-btn" class="menu-btn">☰</button>
    </div>
  </nav>

  <header class="page-hero">
    <div class="hero-bg" style="background-image: url('https://images.unsplash.com/photo-1600585154526-990dced4db0d?q=80&w=2070&auto=format&fit=crop')"></div>
    <div class="hero-content">
      <span class="hero-tag">Lo Que Hacemos</span>
      <h1 class="hero-title"><span class="line">Soluciones de</span><span class="line gold">Reforma Integral</span></h1>
      <p class="hero-sub">Más de 20 años transformando espacios en Valencia y San Diego.</p>
    </div>
  </header>

  <section class="services-page">
    <div class="container">
      <div class="section-header">
        <span class="tag">Nuestros Servicios</span>
        <h2 class="section-title">Transformamos Cada Rincón de Tu Hogar</h2>
        <p class="section-desc">Soluciones completas desde reformas parciales hasta proyectos integrales llave en mano.</p>
      </div>

      <div class="services-vertical-grid">
        {services.map((svc) => (
          <a href={`/servicios/${svc.slug}`} class="service-vertical-card">
            <div class="card-img-wrap">
              <img src={svc.image} alt={svc.title} loading="lazy" />
              <div class="card-overlay"></div>
              <span class="card-icon">✦</span>
            </div>
            <div class="card-body">
              <h3>{svc.title}</h3>
              <p>{svc.desc}</p>
              <ul class="card-features">
                {svc.features.map(f => <li>{f}</li>)}
              </ul>
              <span class="card-link">Ver más detalles <span class="arrow">→</span></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <h2 class="cta-title">¿Listo Para Transformar Tu Espacio?</h2>
      <p class="cta-text">Solicita una consulta gratuita y recibe un presupuesto detallado.</p>
      <a href="/contacto" class="btn-premium btn-primary-premium"><span class="btn-content">Agendar Consulta Gratuita</span><span class="btn-border"></span><span class="btn-shine"></span><span class="btn-arrow">→</span></a>
    </div>
  </section>

  <footer class="footer"><div class="container"><div class="footer-logo">ReformaT<span class="dot">.</span></div><p class="footer-bottom">&copy; {new Date().getFullYear()} ReformaT Venezuela. Todos los derechos reservados.</p></div></footer>

  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Manrope', sans-serif; background: #fff; color: #1a1a1a; overflow-x: hidden; line-height: 1.6; }
    :root { --bg: #0a0a0a; --text: #1a1a1a; --gold: #c9a961; --gold-light: #e6d3a7; --white: #fff; --gray: #f5f5f5; --gray-text: #666; --font-serif: 'Cormorant Garamond', serif; --font-sans: 'Manrope', sans-serif; --container: 1200px; }
    .nav { position: fixed; top: 0; width: 100%; z-index: 100; padding: 25px 0; transition: 0.4s; }
    .nav.scrolled { background: rgba(10,10,10,0.95); backdrop-filter: blur(10px); padding: 15px 0; }
    .nav-container { display: flex; justify-content: space-between; align-items: center; max-width: var(--container); margin: 0 auto; padding: 0 20px; }
    .logo { font-family: var(--font-serif); font-size: 1.8rem; color: var(--white); font-weight: 700; }
    .nav-links { display: flex; gap: 40px; }
    .nav-links a { color: rgba(255,255,255,0.8); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px; transition: 0.3s; }
    .nav-links a:hover, .nav-links a.active { color: var(--gold); }
    .btn-nav-premium { border: 1px solid var(--gold); padding: 8px 20px; border-radius: 2px; color: var(--gold) !important; }
    .menu-btn { display: none; background: none; border: none; color: var(--white); font-size: 1.5rem; cursor: pointer; }
    .page-hero { position: relative; min-height: 60vh; display: flex; align-items: center; justify-content: center; text-align: center; color: var(--white); overflow: hidden; }
    .hero-bg { position: absolute; inset: 0; background-size: cover; background-position: center; z-index: 1; }
    .page-hero::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(0,0,0,0.5), rgba(0,0,0,0.8)); z-index: 2; }
    .hero-content { position: relative; z-index: 3; max-width: 800px; padding: 0 20px; }
    .hero-tag { font-size: 0.9rem; letter-spacing: 3px; text-transform: uppercase; color: var(--gold); margin-bottom: 20px; display: block; }
    .hero-title { font-family: var(--font-serif); font-size: clamp(2.5rem, 6vw, 5rem); font-weight: 300; margin-bottom: 25px; line-height: 1.1; }
    .hero-title .line { display: block; }
    .hero-title .gold { color: var(--gold); }
    .hero-sub { font-size: 1.2rem; color: rgba(255,255,255,0.85); max-width: 600px; margin: 0 auto; }
    .container { max-width: var(--container); margin: 0 auto; padding: 0 20px; }
    .section-header { text-align: center; max-width: 700px; margin: 0 auto 60px; }
    .section-title { font-family: var(--font-serif); font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 20px; }
    .tag { display: inline-block; color: var(--gold); font-size: 0.85rem; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 15px; font-weight: 600; }
    .section-desc { color: var(--gray-text); font-size: 1.1rem; line-height: 1.8; }
    .dot { color: var(--gold); }

    /* SERVICIOS VERTICALES */
    .services-page { padding: 100px 0; background: var(--gray); }
    .services-vertical-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; }
    .service-vertical-card { display: block; background: var(--white); border-radius: 8px; overflow: hidden; box-shadow: 0 5px 20px rgba(0,0,0,0.05); transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); text-decoration: none; color: inherit; }
    .service-vertical-card:hover { transform: translateY(-10px); box-shadow: 0 20px 50px rgba(0,0,0,0.12); }
    .card-img-wrap { position: relative; height: 250px; overflow: hidden; }
    .card-img-wrap img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s; }
    .service-vertical-card:hover .card-img-wrap img { transform: scale(1.08); }
    .card-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.4) 0%, transparent 50%); }
    .card-icon { position: absolute; bottom: 15px; right: 15px; width: 45px; height: 45px; background: var(--gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; color: var(--bg); transition: transform 0.4s; }
    .service-vertical-card:hover .card-icon { transform: scale(1.15) rotate(15deg); }
    .card-body { padding: 30px 25px; }
    .card-body h3 { font-family: var(--font-serif); font-size: 1.5rem; margin-bottom: 12px; color: var(--text); transition: color 0.3s; }
    .service-vertical-card:hover .card-body h3 { color: var(--gold); }
    .card-body p { color: var(--gray-text); font-size: 0.95rem; line-height: 1.7; margin-bottom: 15px; }
    .card-features { list-style: none; margin-bottom: 20px; }
    .card-features li { padding: 6px 0; padding-left: 20px; position: relative; color: var(--text); font-size: 0.9rem; }
    .card-features li::before { content: '✓'; position: absolute; left: 0; color: var(--gold); font-weight: bold; }
    .card-link { color: var(--gold); font-weight: 600; font-size: 0.85rem; letter-spacing: 0.5px; display: inline-flex; align-items: center; gap: 8px; }
    .card-link .arrow { transition: transform 0.3s; display: inline-block; }
    .service-vertical-card:hover .card-link { gap: 14px; }
    .service-vertical-card:hover .card-link .arrow { transform: translateX(5px); }

    .cta-section { padding: 100px 0; background: var(--bg); color: var(--white); text-align: center; }
    .cta-title { font-family: var(--font-serif); font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 20px; }
    .cta-text { color: rgba(255,255,255,0.7); max-width: 500px; margin: 0 auto 40px; font-size: 1.1rem; }
    .btn-premium { position: relative; display: inline-flex; align-items: center; gap: 12px; padding: 18px 45px; font-family: var(--font-sans); font-size: 0.85rem; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; text-decoration: none; border-radius: 4px; overflow: hidden; cursor: pointer; transition: all 0.4s; background: transparent; z-index: 1; }
    .btn-content { position: relative; z-index: 2; }
    .btn-arrow { position: relative; z-index: 2; font-size: 1.1rem; transition: transform 0.4s; display: inline-block; }
    .btn-border { position: absolute; inset: 0; border-radius: 4px; pointer-events: none; z-index: 1; border: 2px solid var(--gold); }
    .btn-shine { position: absolute; top: 0; left: -100%; width: 50%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent); transform: skewX(-20deg); transition: left 0.8s; z-index: 1; pointer-events: none; }
    .btn-primary-premium { background: var(--gold); color: var(--bg); box-shadow: 0 4px 15px rgba(201, 169, 97, 0.3); }
    .btn-primary-premium:hover { transform: translateY(-3px); box-shadow: 0 8px 30px rgba(201, 169, 97, 0.5); }
    .btn-primary-premium:hover .btn-arrow { transform: translateX(8px); }
    .btn-primary-premium:hover .btn-shine { left: 150%; }
    .footer { background: var(--bg); color: rgba(255,255,255,0.6); padding: 50px 0 30px; text-align: center; }
    .footer-logo { font-family: var(--font-serif); font-size: 2rem; color: var(--white); font-weight: 700; margin-bottom: 15px; }
    .footer-bottom { border-top: 1px solid rgba(255,255,255,0.1); padding-top: 25px; font-size: 0.85rem; }
    @media (max-width: 900px) { .nav-links { display: none; } .menu-btn { display: block; } .services-vertical-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 600px) { .services-vertical-grid { grid-template-columns: 1fr; } }
  </style>

  <script>
    window.addEventListener('scroll', () => document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 50));
    const btn = document.getElementById('menu-btn'), nav = document.querySelector('.nav-links');
    if(btn) btn.addEventListener('click', () => { nav.style.display = nav.style.display === 'flex' ? 'none' : 'flex'; nav.style.flexDirection = 'column'; nav.style.position = 'absolute'; nav.style.top = '100%'; nav.style.left = '0'; nav.style.width = '100%'; nav.style.background = '#0a0a0a'; nav.style.padding = '20px'; nav.style.textAlign = 'center'; });
    if(typeof gsap !== 'undefined') { gsap.registerPlugin(ScrollTrigger); gsap.from('.hero-tag', { opacity: 0, y: 20, duration: 1 }); gsap.from('.hero-title .line', { y: 40, opacity: 0, duration: 1, stagger: 0.15, delay: 0.3 }); gsap.from('.hero-sub', { opacity: 0, y: 20, duration: 1, delay: 0.8 }); gsap.utils.toArray('.service-vertical-card').forEach((el, i) => { gsap.from(el, { y: 40, opacity: 0, duration: 0.8, delay: i * 0.1, scrollTrigger: { trigger: el, start: 'top 85%' } }); }); }
  </script>
</body>
</html>