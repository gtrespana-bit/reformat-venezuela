---
import BaseLayout from '../../layouts/BaseLayout.astro';
const getSrcSet = (baseName, widths, ext = 'webp') => {
  return widths.map(w => `/images/${baseName}-${w}.${ext} ${w}w`).join(', ');
};
---

<BaseLayout
  title="About Us | ReformaT Venezuela — European Experience, Local Execution"
  description="ReformaT was born in Spain with over 20 years of experience. For nearly 2 years we've been operating in Venezuela, applying European standards in whole-home renovations, kitchens and bathrooms in Valencia, San Diego, Carabobo and Caracas."
  activePage="home"
>

<!-- HERO -->
<header class="page-hero">
  <img
    src="/images/integrales-800.webp"
    srcset="/images/integrales-400.webp 400w, /images/integrales-800.webp 800w"
    sizes="100vw"
    alt="Whole-home renovation with European standards in Venezuela"
    class="hero-img"
    width="1200" height="600"
    fetchpriority="high"
  />
    <div class="hero-content">
    <span class="tag">About Us</span>
    <h1 class="hero-title">European Experience,<br/><span class="gold">Local Execution</span></h1>
    <p class="hero-subtitle">Over 20 years of experience in Spain. For nearly 2 years we've been bringing European standards to the Venezuelan market, transforming homes with luxury finishes and certified techniques.</p>
  </div>
</header>

<!-- STORY + IMAGE -->
<section class="story-section">
  <div class="container">
    <div class="story-grid">
      <div class="story-text">
        <span class="section-tag">Our Story</span>
        <h2>From Spain to Venezuela:<br/>Excellence Without Borders</h2>
        <p>ReformaT was born in Spain as a company specialized in high-quality whole-home renovations. For over two decades, we built a reputation based on precision, reliability and the impeccable finishes that define European construction.</p>
        <p>Nearly 2 years ago we decided to bring our expertise to the Venezuelan market, identifying a real need: the lack of companies that apply European regulations, respect deadlines and deliver luxury finishes with full transparency.</p>
        <p>Today we operate in <strong>Valencia, San Diego, Carabobo and Caracas</strong>, adapting advanced European construction techniques to local architecture — without sacrificing the quality that defines us.</p>
      </div>
      <div class="story-image">
        <img
          src="/images/cocina-800.webp"
          alt="Kitchen renovation with European finishes in Venezuela"
          width="600" height="450"
          loading="lazy"
        />
        <div class="image-badge">
          <span class="badge-number">20+</span>
          <span class="badge-text">Years of<br/>Experience</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- DIFFERENTIATION -->
<section class="difference-section">
  <div class="container">
    <span class="section-tag light">Why Choose Us</span>
    <h2 class="section-title">European Standards in Venezuela</h2>
    <p class="section-subtitle">The construction and renovation market in Venezuela is known for informality, missed deadlines and poor finishes. ReformaT breaks that pattern.</p>

    <div class="difference-grid">
      <div class="diff-card">
        <div class="diff-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </div>
        <h3>European Regulations</h3>
        <p>We apply Spanish and European regulations on every project: certified electrical installations, standard-compliant plumbing, professional waterproofing and approved materials.</p>
      </div>
      <div class="diff-card">
        <div class="diff-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </div>
        <h3>On-Time Delivery</h3>
        <p>Every project has a defined, contractual timeline. We deliver on date because we plan with precision and supervise every phase. No excuses, no unjustified delays.</p>
      </div>
      <div class="diff-card">
        <div class="diff-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
          </svg>
        </div>
        <h3>Transparent Budgets</h3>
        <p>Detailed, itemized budgets from day one. No hidden costs or surprises. Every dollar and every bolívar is justified and documented.</p>
      </div>
      <div class="diff-card">
        <div class="diff-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
          </svg>
        </div>
        <h3>Luxury Finishes</h3>
        <p>Large-format porcelain, premium fixtures, custom carpentry, professional LED lighting. Every detail reflects the quality that only European experience can deliver.</p>
      </div>
    </div>
  </div>
</section>

<!-- GALLERY -->
<section class="gallery-section">
  <div class="container">
    <span class="section-tag">Our Work</span>
    <h2 class="section-title">Projects That Speak for Themselves</h2>
    <p class="section-subtitle">Every project showcases our commitment to excellence. Perfect finishes, premium materials and attention to detail.</p>

    <div class="gallery-grid">
      <div class="gallery-item large">
        <img
          src="/images/cocina.webp"
          srcset={getSrcSet('cocina', [400, 800])}
          sizes="(max-width: 768px) 100vw, 50vw"
          alt="Kitchen renovation with luxury finishes"
          width="800" height="600"
          loading="lazy"
        />
        <div class="gallery-caption">
          <span>Kitchen Renovation</span>
          <p>Modern design with premium materials</p>
        </div>
      </div>
      <div class="gallery-item">
        <img
          src="/images/bano-terminado-final.webp"
          alt="Bathroom renovation with porcelain and premium fixtures"
          width="400" height="300"
          loading="lazy"
        />
        <div class="gallery-caption">
          <span>Complete Bathroom</span>
          <p>XL porcelain and walk-in shower</p>
        </div>
      </div>
      <div class="gallery-item">
        <img
          src="/images/cocina2.webp"
          alt="Modern kitchen with European design"
          width="400" height="300"
          loading="lazy"
        />
        <div class="gallery-caption">
          <span>Whole-Home Renovation</span>
          <p>Complete space transformation</p>
        </div>
      </div>
      <div class="gallery-item">
        <img
          src="/images/revestimiento-wall-panels.webp"
          alt="Wall coverings with wall panels"
          width="400" height="300"
          loading="lazy"
        />
        <div class="gallery-caption">
          <span>Wall Coverings</span>
          <p>Wall panels and decorative finishes</p>
        </div>
      </div>
      <div class="gallery-item">
        <img
          src="/images/suelo-porcelanato.webp"
          alt="Large-format porcelain flooring"
          width="400" height="300"
          loading="lazy"
        />
        <div class="gallery-caption">
          <span>Premium Flooring</span>
          <p>Large-format porcelain tiles</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- PROCESS -->
<section class="process-section">
  <div class="container">
    <span class="section-tag">How We Work</span>
    <h2 class="section-title">Our Process</h2>
    <p class="section-subtitle">Methodology proven across 500+ projects in Spain. Adapted to the Venezuelan market without losing an ounce of rigor.</p>

    <div class="process-steps">
      <div class="step">
        <span class="step-number">01</span>
        <div class="step-content">
          <h3>Free Technical Visit</h3>
          <p>We visit your home, listen to your needs, evaluate the space and take measurements. No cost, no commitment.</p>
        </div>
      </div>
      <div class="step">
        <span class="step-number">02</span>
        <div class="step-content">
          <h3>Design & Detailed Budget</h3>
          <p>We create 3D renders, an itemized budget with every line item and a defined timeline. Full transparency.</p>
        </div>
      </div>
      <div class="step">
        <span class="step-number">03</span>
        <div class="step-content">
          <h3>Supervised Execution</h3>
          <p>Professional team with a dedicated supervisor. Weekly progress reports and quality control at every phase.</p>
        </div>
      </div>
      <div class="step">
        <span class="step-number">04</span>
        <div class="step-content">
          <h3>Delivery & Warranty</h3>
          <p>Joint final inspection, complete documentation and a 2-year warranty on all workmanship.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- STATS -->
<section class="stats-section">
  <div class="container">
    <div class="stats-grid">
      <div class="stat-item">
        <span class="stat-number">20+</span>
        <span class="stat-label">Years of Experience</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">500+</span>
        <span class="stat-label">Projects in Spain</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">2</span>
        <span class="stat-label">Years in Venezuela</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">100%</span>
        <span class="stat-label">European Standards</span>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-section">
  <div class="container">
    <div class="cta-content">
      <h2>Ready for a Renovation with European Standards?</h2>
      <p>Schedule a free technical visit. We'll analyze your space and prepare a detailed proposal with transparent budgets and guaranteed timelines.</p>
      <div class="cta-buttons">
        <a href="/en/contact" class="btn-premium btn-primary-premium">Request a Quote</a>
        <a href="https://wa.me/584227997043?text=Hi%2C%20I%27m%20interested%20in%20learning%20more%20about%20your%20renovation%20services" target="_blank" rel="noopener" class="btn-premium btn-outline-premium">WhatsApp Direct</a>
      </div>
    </div>
  </div>
</section>

</BaseLayout>

<style>
/* === HERO === */
.page-hero {
  position: relative;
  min-height: 70vh;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  overflow: hidden;
}
.hero-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.hero-content {
  position: relative;
  z-index: 1;
  max-width: 800px;
  padding: 140px 24px 80px;
}
.tag {
  display: inline-block;
  font-family: var(--font-sans, 'Manrope', sans-serif);
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--gold, #c9a961);
  margin-bottom: 20px;
}
.hero-title {
  font-family: var(--font-serif, 'Cormorant Garamond', serif);
  font-size: clamp(2.4rem, 5vw, 4rem);
  font-weight: 400;
  line-height: 1.15;
  color: #fff;
  margin-bottom: 24px;
}
.hero-title .gold { color: var(--gold, #c9a961); }
.hero-subtitle {
  font-size: 1.15rem;
  line-height: 1.7;
  color: rgba(255,255,255,0.8);
  max-width: 650px;
  margin: 0 auto;
}

/* === STORY SECTION === */
.story-section {
  background: #fff;
  padding: 90px 24px;
}
.container {
  max-width: 1100px;
  margin: 0 auto;
}
.story-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
}
.section-tag {
  display: inline-block;
  font-family: var(--font-sans, 'Manrope', sans-serif);
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--gold, #c9a961);
  margin-bottom: 16px;
}
.section-tag.light { color: var(--gold, #c9a961); }
.story-text h2 {
  font-family: var(--font-serif, 'Cormorant Garamond', serif);
  font-size: clamp(1.8rem, 3vw, 2.4rem);
  font-weight: 400;
  color: var(--text, #2a2a2a);
  margin-bottom: 24px;
  line-height: 1.2;
}
.story-text p {
  font-size: 1.05rem;
  line-height: 1.8;
  color: var(--text-light, #555);
  margin-bottom: 16px;
}
.story-image {
  position: relative;
  border-radius: 12px;
  overflow: hidden;
}
.story-image img {
  width: 100%;
  height: 400px;
  object-fit: cover;
  border-radius: 12px;
}
.image-badge {
  position: absolute;
  bottom: 20px;
  right: 20px;
  background: var(--gold, #c9a961);
  color: #0a0a0a;
  padding: 16px 20px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  gap: 10px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.3);
}
.badge-number {
  font-family: var(--font-serif, 'Cormorant Garamond', serif);
  font-size: 2.2rem;
  font-weight: 700;
  line-height: 1;
}
.badge-text {
  font-size: 0.75rem;
  font-weight: 600;
  line-height: 1.3;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

/* === DIFFERENCE SECTION === */
.difference-section {
  background: var(--bg, #0a0a0a);
  padding: 90px 24px;
}
.difference-section .section-title {
  font-family: var(--font-serif, 'Cormorant Garamond', serif);
  font-size: clamp(1.8rem, 3.5vw, 2.6rem);
  font-weight: 400;
  text-align: center;
  color: #fff;
  margin-bottom: 12px;
}
.difference-section .section-subtitle {
  text-align: center;
  font-size: 1.05rem;
  color: rgba(255,255,255,0.7);
  max-width: 700px;
  margin: 0 auto 50px;
  line-height: 1.7;
}
.difference-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24px;
}
.diff-card {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 12px;
  padding: 36px 32px;
  transition: border-color 0.3s ease, transform 0.3s ease;
}
.diff-card:hover {
  border-color: var(--gold, #c9a961);
  transform: translateY(-4px);
}
.diff-icon {
  color: var(--gold, #c9a961);
  margin-bottom: 16px;
}
.diff-card h3 {
  font-family: var(--font-serif, 'Cormorant Garamond', serif);
  font-size: 1.3rem;
  font-weight: 500;
  color: #fff;
  margin-bottom: 10px;
}
.diff-card p {
  font-size: 0.95rem;
  line-height: 1.6;
  color: rgba(255,255,255,0.65);
}

/* === GALLERY SECTION === */
.gallery-section {
  background: #f8f7f4;
  padding: 90px 24px;
}
.gallery-section .section-title {
  font-family: var(--font-serif, 'Cormorant Garamond', serif);
  font-size: clamp(1.8rem, 3.5vw, 2.6rem);
  font-weight: 400;
  text-align: center;
  color: var(--text, #2a2a2a);
  margin-bottom: 12px;
}
.gallery-section .section-subtitle {
  text-align: center;
  font-size: 1.05rem;
  color: var(--text-light, #555);
  max-width: 600px;
  margin: 0 auto 50px;
  line-height: 1.7;
}
.gallery-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}
.gallery-item {
  position: relative;
  border-radius: 12px;
  overflow: hidden;
  aspect-ratio: 4/3;
}
.gallery-item.large {
  grid-column: span 2;
  grid-row: span 2;
  aspect-ratio: auto;
}
.gallery-item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}
.gallery-item:hover img {
  transform: scale(1.05);
}
.gallery-caption {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0,0,0,0.85));
  padding: 30px 20px 16px;
  opacity: 0;
  transition: opacity 0.3s ease;
}
.gallery-item:hover .gallery-caption {
  opacity: 1;
}
.gallery-caption span {
  display: block;
  font-family: var(--font-serif, 'Cormorant Garamond', serif);
  font-size: 1.1rem;
  color: #fff;
  margin-bottom: 4px;
}
.gallery-caption p {
  font-size: 0.8rem;
  color: rgba(255,255,255,0.7);
  margin: 0;
}

/* === PROCESS SECTION === */
.process-section {
  background: #fff;
  padding: 90px 24px;
}
.process-section .section-title {
  font-family: var(--font-serif, 'Cormorant Garamond', serif);
  font-size: clamp(1.8rem, 3.5vw, 2.6rem);
  font-weight: 400;
  text-align: center;
  color: var(--text, #2a2a2a);
  margin-bottom: 12px;
}
.process-section .section-subtitle {
  text-align: center;
  font-size: 1.05rem;
  color: var(--text-light, #555);
  max-width: 600px;
  margin: 0 auto 50px;
  line-height: 1.7;
}
.process-steps {
  display: flex;
  flex-direction: column;
  gap: 20px;
  max-width: 750px;
  margin: 0 auto;
}
.step {
  display: flex;
  align-items: flex-start;
  gap: 24px;
  background: #f8f7f4;
  border: 1px solid rgba(0,0,0,0.06);
  border-radius: 12px;
  padding: 28px 32px;
  transition: border-color 0.3s ease;
}
.step:hover {
  border-color: var(--gold, #c9a961);
}
.step-number {
  font-family: var(--font-serif, 'Cormorant Garamond', serif);
  font-size: 2.4rem;
  font-weight: 400;
  color: var(--gold, #c9a961);
  min-width: 55px;
  line-height: 1;
}
.step-content h3 {
  font-family: var(--font-sans, 'Manrope', sans-serif);
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--text, #2a2a2a);
  margin-bottom: 8px;
}
.step-content p {
  font-size: 0.95rem;
  line-height: 1.6;
  color: var(--text-light, #555);
  margin: 0;
}

/* === STATS SECTION === */
.stats-section {
  background: var(--gold, #c9a961);
  padding: 60px 24px;
}
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 30px;
  text-align: center;
}
.stat-item {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.stat-number {
  font-family: var(--font-serif, 'Cormorant Garamond', serif);
  font-size: clamp(2.2rem, 4vw, 3rem);
  font-weight: 700;
  color: #0a0a0a;
  line-height: 1;
}
.stat-label {
  font-family: var(--font-sans, 'Manrope', sans-serif);
  font-size: 0.85rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: rgba(10,10,10,0.7);
}

/* === CTA SECTION === */
.cta-section {
  background: var(--bg, #0a0a0a);
  padding: 100px 24px;
  text-align: center;
}
.cta-content {
  max-width: 700px;
  margin: 0 auto;
}
.cta-content h2 {
  font-family: var(--font-serif, 'Cormorant Garamond', serif);
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 400;
  color: #fff;
  margin-bottom: 20px;
  line-height: 1.2;
}
.cta-content p {
  font-size: 1.1rem;
  line-height: 1.7;
  color: rgba(255,255,255,0.75);
  margin-bottom: 36px;
}
.cta-buttons {
  display: flex;
  gap: 16px;
  justify-content: center;
  flex-wrap: wrap;
}
.btn-premium {
  display: inline-block;
  font-family: var(--font-sans, 'Manrope', sans-serif);
  font-size: 0.85rem;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  padding: 16px 40px;
  border-radius: 4px;
  text-decoration: none;
  transition: all 0.3s ease;
}
.btn-primary-premium {
  background: var(--gold, #c9a961);
  color: #0a0a0a;
}
.btn-primary-premium:hover {
  background: var(--gold-light, #e6d3a7);
}
.btn-outline-premium {
  background: transparent;
  color: #fff;
  border: 1px solid rgba(255,255,255,0.3);
}
.btn-outline-premium:hover {
  border-color: var(--gold, #c9a961);
  color: var(--gold, #c9a961);
}

/* === RESPONSIVE === */
@media (max-width: 768px) {
  .page-hero { min-height: 55vh; }
  .hero-content { padding: 120px 20px 60px; }
  .story-grid { grid-template-columns: 1fr; gap: 40px; }
  .story-image img { height: 300px; }
  .difference-grid { grid-template-columns: 1fr; }
  .gallery-grid { grid-template-columns: 1fr 1fr; }
  .gallery-item.large { grid-column: span 2; grid-row: span 1; aspect-ratio: 16/9; }
  .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 24px; }
  .step { flex-direction: column; gap: 12px; }
  .step-number { font-size: 2rem; min-width: auto; }
  .cta-section { padding: 80px 20px; }
  .cta-buttons { flex-direction: column; align-items: center; }
}
</style>
