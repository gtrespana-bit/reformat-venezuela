---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About Us | ReformaT Venezuela — Over 20 Years Transforming Homes"
  description="Meet the ReformaT Venezuela team. Over 20 years of experience in whole-home renovations, kitchens and bathrooms in Valencia, San Diego, Carabobo and Caracas. Commitment, quality and transparency."
  activePage="home"
>

<!-- HERO -->
<header class="about-hero">
  <div class="hero-bg" style="background-image: url('/images/equipo-reformat.webp')"></div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <span class="article-category">Who We Are</span>
    <h1 class="article-title"><span class="line">Over 20 Years</span><span class="line gold">Transforming Homes</span></h1>
    <p class="article-excerpt">We are a team of Venezuelan professionals dedicated to turning ordinary spaces into extraordinary places. Every renovation tells a story.</p>
  </div>
</header>

<!-- ABOUT INTRO -->
<section class="about-section">
  <div class="about-container">
    <div class="about-body">
      <h2>Our Story</h2>
      <p>ReformaT Venezuela was born from a passion for design and functional construction. For over two decades, we have transformed hundreds of homes across Valencia, San Diego, Carabobo and Caracas, building trust one project at a time.</p>
      <p>We are not just contractors — we are partners in creating the spaces where your best moments happen. From a modern kitchen to a full renovation, every detail matters.</p>

      <h2>Our Mission</h2>
      <p>To deliver high-quality renovations with transparency, on-time delivery and fair pricing. We believe every Venezuelan family deserves a home that inspires them — and we work every day to make that possible.</p>

      <h2>Our Vision</h2>
      <p>To be the leading renovation company in central Venezuela, recognized for excellence, innovation and unwavering commitment to our clients.</p>
    </div>

    <!-- VALUES -->
    <div class="values-grid">
      <div class="value-card">
        <span class="value-icon">✦</span>
        <h3>Quality</h3>
        <p>Premium materials and certified professionals in every project.</p>
      </div>
      <div class="value-card">
        <span class="value-icon">◈</span>
        <h3>Transparency</h3>
        <p>Clear budgets, weekly reports and zero surprise costs.</p>
      </div>
      <div class="value-card">
        <span class="value-icon">◎</span>
        <h3>Commitment</h3>
        <p>Agreed timelines and 2-year workmanship warranty.</p>
      </div>
      <div class="value-card">
        <span class="value-icon">▣</span>
        <h3>Innovation</h3>
        <p>Modern designs, current trends and cutting-edge technology.</p>
      </div>
    </div>
  </div>
</section>

<!-- PROCESS -->
<section class="process-section">
  <div class="about-container">
    <h2 class="section-title">Our Process</h2>
    <p class="section-subtitle">From the first visit to final handover — clear and structured.</p>

    <div class="process-steps">
      <div class="step">
        <span class="step-number">01</span>
        <h3>Initial Visit</h3>
        <p>We visit your home, listen to your ideas and take measurements at no cost.</p>
      </div>
      <div class="step">
        <span class="step-number">02</span>
        <h3>Design & Budget</h3>
        <p>3D renders, itemized budget and defined timeline. No surprises.</p>
      </div>
      <div class="step">
        <span class="step-number">03</span>
        <h3>Execution</h3>
        <p>Our team gets to work with weekly progress reports and a dedicated supervisor.</p>
      </div>
      <div class="step">
        <span class="step-number">04</span>
        <h3>Quality Control</h3>
        <p>Internal inspection before final handover. Nothing is left to chance.</p>
      </div>
      <div class="step">
        <span class="step-number">05</span>
        <h3>Delivery & Warranty</h3>
        <p>Joint final inspection, documentation handover and 2-year workmanship warranty.</p>
      </div>
    </div>

    <h2>Certifications & Warranties</h2>
    <ul class="cert-list">
      <li><strong>2-year warranty</strong> on all workmanship</li>
      <li>Certified electricians and plumbers</li>
      <li>Premium materials with manufacturer warranty</li>
      <li>Post-delivery technical support</li>
    </ul>
  </div>
</section>

<!-- CTA -->
<section class="cta-section">
  <div class="cta-wrapper">
    <h2 class="cta-title">Ready to Transform Your Home?</h2>
    <p class="cta-text">Schedule a free visit. We'll analyze your space and prepare a detailed proposal — no commitment.</p>
    <a href="/en/contact" class="btn-premium">Request Free Quote</a>
  </div>
</section>

</BaseLayout>

<style>
/* === HERO (dark, matches site style) === */
.about-hero {
  position: relative;
  min-height: 65vh;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 140px 24px 80px;
  overflow: hidden;
}
.hero-bg {
  position: absolute;
  inset: 0;
  background-size: cover;
  background-position: center;
  filter: brightness(0.3);
}
.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(10,10,10,0.6) 0%, rgba(10,10,10,0.85) 100%);
}
.hero-content {
  position: relative;
  z-index: 1;
  max-width: 800px;
}
.article-category {
  display: inline-block;
  font-family: var(--font-sans, 'Manrope', sans-serif);
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--gold, #c9a961);
  margin-bottom: 20px;
}
.article-title {
  font-family: var(--font-serif, 'Cormorant Garamond', serif);
  font-size: clamp(2.4rem, 5vw, 4rem);
  font-weight: 400;
  line-height: 1.15;
  color: #fff;
  margin-bottom: 24px;
}
.article-title .line { display: block; }
.article-title .gold { color: var(--gold, #c9a961); }
.article-excerpt {
  font-size: 1.15rem;
  line-height: 1.7;
  color: rgba(255,255,255,0.8);
  max-width: 600px;
  margin: 0 auto;
}

/* === ABOUT SECTION (white background) === */
.about-section {
  background: #fff;
  padding: 80px 24px;
}
.about-container {
  max-width: 960px;
  margin: 0 auto;
}
.about-body h2 {
  font-family: var(--font-serif, 'Cormorant Garamond', serif);
  font-size: 1.8rem;
  font-weight: 400;
  color: var(--text, #2a2a2a);
  margin: 40px 0 16px;
}
.about-body h2:first-child { margin-top: 0; }
.about-body p {
  font-size: 1.05rem;
  line-height: 1.8;
  color: var(--text-light, #555);
  margin-bottom: 16px;
}

/* === VALUES GRID === */
.values-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24px;
  margin-top: 50px;
}
.value-card {
  background: #f8f7f4;
  border: 1px solid rgba(0,0,0,0.06);
  border-radius: 12px;
  padding: 32px 28px;
  text-align: center;
}
.value-icon {
  display: block;
  font-size: 1.6rem;
  color: var(--gold, #c9a961);
  margin-bottom: 12px;
}
.value-card h3 {
  font-family: var(--font-serif, 'Cormorant Garamond', serif);
  font-size: 1.3rem;
  font-weight: 500;
  color: var(--text, #2a2a2a);
  margin-bottom: 8px;
}
.value-card p {
  font-size: 0.95rem;
  line-height: 1.6;
  color: var(--text-light, #555);
}

/* === PROCESS SECTION (light cream) === */
.process-section {
  background: #f8f7f4;
  padding: 80px 24px;
}
.section-title {
  font-family: var(--font-serif, 'Cormorant Garamond', serif);
  font-size: clamp(1.8rem, 3.5vw, 2.6rem);
  font-weight: 400;
  text-align: center;
  color: var(--text, #2a2a2a);
  margin-bottom: 12px;
}
.section-subtitle {
  text-align: center;
  font-size: 1.05rem;
  color: var(--text-light, #555);
  margin-bottom: 50px;
}
.process-steps {
  display: flex;
  flex-direction: column;
  gap: 20px;
  margin-bottom: 50px;
}
.step {
  display: flex;
  align-items: flex-start;
  gap: 20px;
  background: #fff;
  border: 1px solid rgba(0,0,0,0.06);
  border-radius: 12px;
  padding: 24px 28px;
}
.step-number {
  font-family: var(--font-serif, 'Cormorant Garamond', serif);
  font-size: 2.2rem;
  font-weight: 400;
  color: var(--gold, #c9a961);
  min-width: 50px;
  line-height: 1;
}
.step h3 {
  font-family: var(--font-sans, 'Manrope', sans-serif);
  font-size: 1.05rem;
  font-weight: 600;
  color: var(--text, #2a2a2a);
  margin-bottom: 6px;
}
.step p {
  font-size: 0.95rem;
  line-height: 1.6;
  color: var(--text-light, #555);
  margin: 0;
}

.process-section h2 {
  font-family: var(--font-serif, 'Cormorant Garamond', serif);
  font-size: 1.6rem;
  font-weight: 400;
  color: var(--text, #2a2a2a);
  margin-bottom: 16px;
}
.cert-list {
  list-style: none;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.cert-list li {
  font-size: 1rem;
  color: var(--text-light, #555);
  padding-left: 24px;
  position: relative;
}
.cert-list li::before {
  content: '✓';
  position: absolute;
  left: 0;
  color: var(--gold, #c9a961);
  font-weight: 700;
}

/* === CTA (dark, matches site) === */
.cta-section {
  background: var(--bg, #0a0a0a);
  padding: 100px 24px;
  text-align: center;
}
.cta-wrapper {
  max-width: 700px;
  margin: 0 auto;
}
.cta-title {
  font-family: var(--font-serif, 'Cormorant Garamond', serif);
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 400;
  color: #fff;
  margin-bottom: 20px;
  line-height: 1.2;
}
.cta-text {
  font-size: 1.1rem;
  line-height: 1.7;
  color: rgba(255,255,255,0.75);
  margin-bottom: 36px;
}
.btn-premium {
  display: inline-block;
  background: var(--gold, #c9a961);
  color: #0a0a0a;
  font-family: var(--font-sans, 'Manrope', sans-serif);
  font-size: 0.9rem;
  font-weight: 600;
  letter-spacing: 1px;
  text-transform: uppercase;
  padding: 16px 44px;
  border-radius: 4px;
  text-decoration: none;
  transition: background 0.3s ease;
}
.btn-premium:hover {
  background: var(--gold-light, #e6d3a7);
}

/* === RESPONSIVE === */
@media (max-width: 768px) {
  .about-hero { min-height: 55vh; padding: 120px 20px 60px; }
  .about-body h2 { font-size: 1.5rem; }
  .values-grid { grid-template-columns: 1fr; }
  .step { flex-direction: column; gap: 8px; }
  .step-number { font-size: 1.8rem; min-width: auto; }
  .cta-section { padding: 80px 20px; }
}
</style>
