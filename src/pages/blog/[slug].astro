---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
export async function getStaticPaths() { const posts = await getCollection('blog'); return posts.map((post) => ({ params: { slug: post.slug }, props: { post } })); }
const { post } = Astro.props;
if (!post) { return Astro.redirect('/blog'); }
const { data, slug, render } = post;
const { Content } = await render();
const allPosts = await getCollection('blog');
const related = allPosts.filter(p => p.data.category === data.category && p.slug !== slug).slice(0, 2);
---
<BaseLayout title={`${data.title} | ReformaT Venezuela`} description={data.excerpt} image={data.image} activePage="blog">
  <header class="article-hero"><div class="hero-bg" style="background-image: url('{data.image}')"></div><div class="hero-overlay"></div><div class="hero-content"><a href="/blog" class="back-link">← Volver al Blog</a><span class="article-category">{data.category}</span><h1 class="article-title">{data.title}</h1><p class="article-excerpt">{data.excerpt}</p><div class="article-meta"><span>{data.date.toLocaleDateString('es-VE', { year: 'numeric', month: 'long', day: 'numeric' })}</span><span>•</span><span>{data.readTime} lectura</span><span>•</span><span>Por {data.author}</span></div></div></header>
  <article class="article-section"><div class="container"><div class="article-body"><Content /></div><div class="share-section"><span>Compartir:</span><div class="share-btns"><button onclick="shareArticle('whatsapp')" class="share-btn wa">WA</button><button onclick="shareArticle('facebook')" class="share-btn fb">FB</button></div></div></div></article>
  {related.length > 0 && (<section class="related-section"><div class="container"><h3 class="section-title">Artículos <span class="gold">Relacionados</span></h3><div class="related-grid">{related.map(rel => (<a href={`/blog/${rel.slug}`} class="related-card"><div class="related-img"><img src={rel.data.image || ''} alt={rel.data.title} loading="lazy" /></div><div class="related-content"><span class="related-cat">{rel.data.category}</span><h4>{rel.data.title}</h4><p>{rel.data.excerpt}</p></div></a>))}</div></div></section>)}
  
  <section class="cta-section">
    <div class="cta-wrapper">
      <h2 class="cta-title">¿Listo Para Transformar Tu Espacio?</h2>
      <p class="cta-text">Solicita una consulta gratuita y recibe un presupuesto detallado sin compromiso.</p>
      <a href="/contacto" class="btn-premium btn-primary-premium"><span class="btn-content">Agendar Consulta Gratuita</span><span class="btn-border"></span><span class="btn-shine"></span><span class="btn-arrow">→</span></a>
    </div>
  </section>
</BaseLayout>
<style>
  .share-section { display: flex; align-items: center; justify-content: space-between; margin-top: 60px; padding: 25px 0; border-top: 1px solid #eee; border-bottom: 1px solid #eee; max-width: 800px; margin-left: auto; margin-right: auto; }
  .share-btn { width: 45px; height: 45px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; font-weight: 700; border: none; cursor: pointer; transition: 0.3s; color: white; }
  .share-btn.wa { background: #25D366; }
  .share-btn.fb { background: #1877F2; }
  .share-btn:hover { transform: translateY(-4px); }
  .related-section { padding: 100px 0; background: var(--bg); color: var(--white); }
  .related-section .section-title { text-align: center; margin-bottom: 50px; font-family: var(--font-serif); font-size: clamp(2rem, 4vw, 3rem); font-weight: 300; color: var(--white); }
  .related-section .gold { color: var(--gold); }
  .related-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 40px; }
  .related-card { display: block; background: #111; border-radius: 12px; overflow: hidden; transition: 0.4s; text-decoration: none; color: inherit; border: 1px solid rgba(255,255,255,0.05); }
  .related-card:hover { transform: translateY(-8px); border-color: var(--gold); }
  .related-img { height: 220px; overflow: hidden; }
  .related-img img { width: 100%; height: 100%; object-fit: cover; transition: 0.6s; }
  .related-card:hover .related-img img { transform: scale(1.05); }
  .related-content { padding: 25px; }
  .related-cat { font-size: 0.75rem; color: var(--gold); text-transform: uppercase; letter-spacing: 1px; font-weight: 600; margin-bottom: 10px; display: block; }
  .related-content h4 { font-family: var(--font-serif); font-size: 1.5rem; margin-bottom: 12px; line-height: 1.3; color: var(--white); }
  .related-content p { color: rgba(255,255,255,0.6); font-size: 0.95rem; line-height: 1.6; }
  @media (max-width: 900px) { .related-grid { grid-template-columns: 1fr; } .share-section { flex-direction: column; gap: 20px; text-align: center; } }
</style>