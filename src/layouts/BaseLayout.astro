---
import '../styles/global.css';
import Analytics from '../components/Analytics.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  activePage?: 'inicio' | 'servicios' | 'proyectos' | 'blog' | 'contacto';
}

const { title, description, image = '', activePage = '' } = Astro.props;
const siteUrl = 'https://reformat-venezuela.online';
const currentPath = Astro.url.pathname;
const ogImage = image && image.startsWith('http') 
  ? image 
  : `${siteUrl}${image || '/images/og-default.jpg'}`;
const siteName = 'ReformaT Venezuela';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={`${siteUrl}${currentPath}`} />
  
  <link rel="icon" type="image/jpeg" href="/images/favicon.jpg" />
  <link rel="shortcut icon" type="image/jpeg" href="/images/favicon.jpg" />
  <link rel="apple-touch-icon" href="/images/favicon.jpg" />
  
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:locale" content="es_VE" />
  <meta property="og:url" content={`${siteUrl}${currentPath}`} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:secure_url" content={ogImage} />
  <meta property="og:image:type" content="image/jpeg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={`${siteName} - Reformas de calidad en Valencia, San Diego, Carabobo y Caracas`} />
  
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="twitter:image:alt" content={`${siteName} - Reformas de calidad en Valencia, San Diego, Carabobo y Caracas`} />
  
  <meta name="author" content={siteName} />
  <meta name="theme-color" content="#0a0a0a" />
  <meta name="robots" content="index, follow" />
  
  <Analytics />
  <link rel="preload" href="/fonts/cormorant-garamond-v21-latin-400.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/cormorant-garamond-v21-latin-500.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/cormorant-garamond-v21-latin-600.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/cormorant-garamond-v21-latin-700.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/manrope-v15-latin-400.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/manrope-v15-latin-500.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/manrope-v15-latin-600.woff2" as="font" type="font/woff2" crossorigin />
  
  <!-- âœ… FUENTES AUTO-ALOJADAS: Sin bloqueo de renderizado -->
  <link rel="preload" href="/fonts/cormorant-garamond-v16-latin-regular.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/cormorant-garamond-v16-latin-500.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/cormorant-garamond-v16-latin-600.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/cormorant-garamond-v16-latin-700.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/manrope-v15-latin-regular.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/manrope-v15-latin-500.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/manrope-v15-latin-600.woff2" as="font" type="font/woff2" crossorigin />
  
  <!-- CSS crÃ­tico inline (Astro lo inyecta automÃ¡ticamente) -->
  
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" defer></script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "HomeAndConstructionBusiness",
    "name": "ReformaT Venezuela",
    "image": "/images/logo-header.webp",
    "url": "https://reformat-venezuela.online",
    "telephone": "+584227997043",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Valencia",
      "addressRegion": "Carabobo",
      "addressCountry": "VE"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 10.1620,
      "longitude": -68.0077
    },
    "areaServed": [
      {"@type": "City", "name": "Valencia"},
      {"@type": "City", "name": "San Diego"},
      {"@type": "AdministrativeArea", "name": "Carabobo"},
      {"@type": "City", "name": "Caracas"}
    ],
    "priceRange": "$$",
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "08:00",
      "closes": "18:00"
    }
  }
  </script>
</head>

<body>
  <a href="#main-content" class="skip-link">Saltar al contenido principal</a>

  <nav id="navbar" class="nav" role="navigation" aria-label="MenÃº principal">
    <div class="nav-container">
      <a href="/" class="logo">
        <img 
          src="/images/logo-header.webp" 
          alt="ReformaT Venezuela - RemodelaciÃ³n de Viviendas" 
          width="200"
          height="auto"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </a>
      
      <ul class="nav-links">
        <li><a href="/" class={activePage === 'inicio' ? 'active' : ''}>Inicio</a></li>
        <li><a href="/servicios" class={activePage === 'servicios' ? 'active' : ''}>Servicios</a></li>
        <li><a href="/proyectos" class={activePage === 'proyectos' ? 'active' : ''}>Proyectos</a></li>
        <li><a href="/blog" class={activePage === 'blog' ? 'active' : ''}>Blog</a></li>
        <li><a href="/contacto" class="btn-nav-premium">Contacto</a></li>
      </ul>
      <button id="menu-btn" class="menu-btn" aria-label="Abrir menÃº de navegaciÃ³n">â˜°</button>
    </div>
  </nav>

  <main id="main-content"><slot /></main>

  <a href="https://wa.me/584227997043?text=Hola,%20me%20interesa%20una%20consulta%20para%20mi%20proyecto" target="_blank" class="whatsapp-float" aria-label="Contactar por WhatsApp">
    <svg viewBox="0 0 24 24" fill="white" width="28" height="28"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
  </a>

  <footer class="footer">
    <div class="container">
      <div class="footer-logo">
        <img 
          src="/images/logo-footer.webp" 
          alt="ReformaT Venezuela - RemodelaciÃ³n de Viviendas" 
          width="500"
          height="auto"
          loading="lazy"
          decoding="async"
        />
      </div>
      <p class="footer-desc">Transformando espacios con excelencia desde 2005.</p>
      <p class="footer-bottom">&copy; {new Date().getFullYear()} ReformaT Venezuela. Todos los derechos reservados. | Valencia, San Diego, Carabobo y Caracas.</p>
    </div>
  </footer>

  <script>
    window.addEventListener('scroll', () => document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 80));
    const menuBtn = document.getElementById('menu-btn'), navLinks = document.querySelector('.nav-links');
    if (menuBtn && navLinks) menuBtn.addEventListener('click', () => { 
      const isOpen = navLinks.style.display === 'flex';
      navLinks.style.display = isOpen ? 'none' : 'flex'; 
      navLinks.style.flexDirection = 'column'; 
      navLinks.style.position = 'absolute'; 
      navLinks.style.top = '100%'; 
      navLinks.style.left = '0'; 
      navLinks.style.width = '100%'; 
      navLinks.style.background = '#0a0a0a'; 
      navLinks.style.padding = '20px'; 
      navLinks.style.textAlign = 'center'; 
      menuBtn.setAttribute('aria-expanded', !isOpen);
    });
    window.shareArticle = (platform) => { const url = window.location.href; const title = document.title; const links = { whatsapp: `https://wa.me/?text=${encodeURIComponent(title + ' ' + url)}`, facebook: `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}` }; if(links[platform]) window.open(links[platform], '_blank', 'width=600,height=400'); };
  </script>
</body>
</html>

<style>
  .skip-link {
    position: absolute; top: -40px; left: 0; background: #0a0a0a; color: #fff;
    padding: 12px 16px; z-index: 9999; transition: top 0.3s; text-decoration: none;
  }
  .skip-link:focus { top: 0; }
  *:focus-visible { outline: 2px solid #C9A961; outline-offset: 2px; }
  button:focus-visible, a:focus-visible { outline: 2px solid #C9A961; outline-offset: 2px; }
  
  .nav { position: fixed; top: 0; left: 0; width: 100%; background: transparent; z-index: 1000; padding: 20px 0; transition: background 0.4s, padding 0.4s; }
  .nav.scrolled { background: rgba(10,10,10,0.95); padding: 15px 0; border-bottom: 1px solid rgba(201,169,97,0.2); }
  .nav-container { display: flex; justify-content: space-between; align-items: center; max-width: 1200px; margin: 0 auto; padding: 0 20px; }
  .logo { display: flex; align-items: center; }
  .logo img { height: 85px; width: auto; display: block; transition: height 0.3s; }
  .nav.scrolled .logo img { height: 70px; }
  .nav-links { display: flex; gap: 35px; list-style: none; align-items: center; }
  .nav-links a { color: rgba(255,255,255,0.9); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px; transition: color 0.3s; position: relative; font-weight: 400; }
  .nav-links a:hover, .nav-links a.active { color: var(--gold); }
  .nav-links a.active::after { content: ''; position: absolute; bottom: -5px; left: 0; width: 100%; height: 2px; background: var(--gold); }
  .btn-nav-premium { border: 1px solid var(--gold); padding: 8px 22px; border-radius: 2px; color: var(--gold) !important; font-weight: 500; }
  .btn-nav-premium:hover { background: var(--gold); color: var(--bg) !important; }
  .menu-btn { display: none; background: none; border: none; color: var(--white); font-size: 1.5rem; cursor: pointer; }

  .whatsapp-float { position: fixed; bottom: 25px; right: 25px; width: 60px; height: 60px; background: #25D366; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 20px rgba(37, 211, 102, 0.4); transition: all 0.3s; z-index: 99; }
  .whatsapp-float:hover { transform: scale(1.1); box-shadow: 0 6px 25px rgba(37, 211, 102, 0.6); }

  .footer { background: var(--bg); color: rgba(255,255,255,0.7); padding: 90px 0 45px; text-align: center; }
  .footer-logo { margin-bottom: 35px; display: flex; justify-content: center; }
  .footer-logo img { max-width: 450px; height: auto; display: block; }
  .footer-desc { max-width: 420px; margin: 0 auto 28px; font-size: 1rem; line-height: 1.6; }
  .footer-bottom { border-top: 1px solid rgba(255,255,255,0.12); padding-top: 28px; font-size: 0.85rem; color: rgba(255,255,255,0.5); }

  @media (max-width: 900px) { .nav-links { display: none; } .menu-btn { display: block; } }
  @media (max-width: 768px) { .logo img { height: 60px; } .nav.scrolled .logo img { height: 55px; } .footer-logo img { max-width: 350px; } .whatsapp-float { width: 55px; height: 55px; bottom: 20px; right: 20px; } }
  @media (max-width: 480px) { .logo img { height: 55px; } .footer-logo img { max-width: 300px; } .footer { padding: 70px 0 35px; } }
</style>
